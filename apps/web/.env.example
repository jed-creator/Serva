# Orvo web app — environment variables
#
# Copy this file to `.env.local` and fill in real values for local
# development. For production, set the same keys in the Vercel
# project settings (Settings → Environment Variables).
#
# Keys prefixed with NEXT_PUBLIC_ are inlined into the browser bundle
# and visible to clients. Everything else is server-only — never expose
# them to the client.

# ---------------------------------------------------------------------
# Supabase (database, auth, storage)
# ---------------------------------------------------------------------
# Project URL — find under Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (publishable) key — Project Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — Project Settings → API → Project API keys
# WARNING: bypasses Row Level Security. Server-only. Never ship to client.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Stripe (Connect onboarding for businesses + future payment intents)
# ---------------------------------------------------------------------
# Secret key — Stripe Dashboard → Developers → API keys
# Use a `sk_test_...` key in dev, `sk_live_...` in production.
STRIPE_SECRET_KEY=

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks → (your endpoint) → Signing secret
# Required by app/api/stripe/webhook/route.ts to verify event signatures.
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------
# API key — resend.com/api-keys
RESEND_API_KEY=

# Verified sending address — must be on a domain you control and have
# verified in Resend. Falls back to onboarding@resend.dev if unset, but
# that address is rate-limited and only allowed to your own account email.
RESEND_FROM_EMAIL=hello@orvo.app

# ---------------------------------------------------------------------
# Twilio (SMS reminders)
# ---------------------------------------------------------------------
# Account SID — twilio.com/console
TWILIO_ACCOUNT_SID=

# Auth token — twilio.com/console (rotate if leaked)
TWILIO_AUTH_TOKEN=

# Phone number that messages send from. Must be a Twilio number you own,
# in E.164 format (e.g. +15555551234).
TWILIO_PHONE_NUMBER=

# ---------------------------------------------------------------------
# App configuration
# ---------------------------------------------------------------------
# Public-facing base URL for the web app. Used in Stripe Connect return
# URLs and email templates. In production this should match your custom
# domain (e.g. https://orvo.app). Locally, leave the default.
NEXT_PUBLIC_APP_URL=http://localhost:3333

# Bearer token that Vercel Cron presents to /api/cron/send-reminders.
# Generate with `openssl rand -hex 32`. Set the same value here AND in
# Vercel Project Settings → Environment Variables. Vercel Cron will
# automatically include `Authorization: Bearer ${CRON_SECRET}` on every
# scheduled invocation when this env var is set on the deployment.
CRON_SECRET=

# ---------------------------------------------------------------------
# Test / CI (optional)
# ---------------------------------------------------------------------
# Override the base URL Playwright tests hit. Defaults to
# http://localhost:3333. Set to your preview deployment URL when running
# E2E tests against a Vercel preview.
# TEST_BASE_URL=
