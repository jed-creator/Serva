{
  "name": "@orvo/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, schemas, and utilities for Orvo apps",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./super-app": {
      "types": "./src/super-app/index.ts",
      "default": "./src/super-app/index.ts"
    },
    "./super-app/*": {
      "types": "./src/super-app/*.ts",
      "default": "./src/super-app/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
