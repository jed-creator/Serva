# Orvo Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is gitignored.

# =============================================================================
# SUPABASE (Step 6)
# =============================================================================
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key...

# =============================================================================
# STRIPE (Step 7)
# =============================================================================
# Get these from: Stripe Dashboard → Developers → API keys
# Use TEST keys for development (pk_test_..., sk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Stripe webhook signing secret — we'll set this when we configure webhooks in Phase 4
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# RESEND — Transactional Email (Step 9)
# =============================================================================
# Get this from: Resend Dashboard → API Keys
RESEND_API_KEY=re_...
# Email "from" address — must be a verified domain in Resend, or use resend.dev for dev
RESEND_FROM_EMAIL=noreply@orvo.dev

# =============================================================================
# TWILIO — SMS (Step 10)
# =============================================================================
# Get these from: Twilio Console → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15555551234

# =============================================================================
# APP CONFIG
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
